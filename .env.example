# Copy this file to .env.local and fill in real values before running
# Never commit .env or .env.local to version control

# --- RPC Endpoints ---
VITE_STELLAR_RPC_URL=https://horizon-testnet.stellar.org
VITE_ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY_HERE
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_BNB_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# --- Contract Addresses (testnet) ---
VITE_STELLAR_AMM_CONTRACT=CDEMO_STELLAR_AMM
VITE_STELLAR_BRIDGE_CONTRACT=CDEMO_STELLAR_BRIDGE
VITE_ETH_BRIDGE_CONTRACT=0xDEMO_ETH_BRIDGE
VITE_SOLANA_BRIDGE_PROGRAM=DEMO_SOLANA_PROGRAM
VITE_BNB_BRIDGE_CONTRACT=0xDEMO_BNB_BRIDGE

# --- Feature flags ---
VITE_NETWORK=testnet
VITE_ENABLE_MAINNET=false
